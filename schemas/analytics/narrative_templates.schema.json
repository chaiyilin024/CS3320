{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cs3320.local/schemas/analytics/narrative_templates.schema.json",
  "title": "GlobalNarrativeTemplates",
  "description": "跨剧本叙事模板对比 — artifacts/analytics/global/narrative_templates.json",
  "type": "object",
  "required": ["version", "generated_at", "templates"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "$ref": "../common/definitions.schema.json#/$defs/version"
    },
    "generated_at": {
      "$ref": "../common/definitions.schema.json#/$defs/isoDateTime"
    },
    "templates": {
      "type": "array",
      "items": { "$ref": "#/$defs/narrativeTemplate" }
    },
    "by_genre": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["genre", "avg_stage_lengths"],
        "properties": {
          "genre": {
            "$ref": "../common/definitions.schema.json#/$defs/genre"
          },
          "play_count": { "type": "integer", "minimum": 0 },
          "avg_stage_lengths": {
            "type": "object",
            "additionalProperties": { "type": "number", "minimum": 0 },
            "description": "各情节阶段平均块数占比"
          },
          "avg_rhythm_curve": {
            "type": "array",
            "items": { "$ref": "narrative.schema.json#/$defs/rhythmPoint" },
            "description": "归一化后的平均节奏曲线"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "narrativeTemplate": {
      "type": "object",
      "required": ["template_id", "label", "play_count"],
      "additionalProperties": false,
      "properties": {
        "template_id": { "type": "string" },
        "label": {
          "type": "string",
          "examples": ["起承转合型", "高潮前置型"]
        },
        "play_count": { "type": "integer", "minimum": 0 },
        "example_script_ids": {
          "type": "array",
          "items": {
            "$ref": "../common/definitions.schema.json#/$defs/scriptId"
          }
        },
        "stage_proportions": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
