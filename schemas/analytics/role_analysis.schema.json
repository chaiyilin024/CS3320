{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cs3320.local/schemas/analytics/role_analysis.schema.json",
  "title": "GlobalRoleAnalysis",
  "description": "跨剧本行当分析 — artifacts/analytics/global/role_analysis.json",
  "type": "object",
  "required": ["version", "generated_at", "global_feature_hangdang_matrix"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "$ref": "../common/definitions.schema.json#/$defs/version"
    },
    "generated_at": {
      "$ref": "../common/definitions.schema.json#/$defs/isoDateTime"
    },
    "global_feature_hangdang_matrix": {
      "type": "array",
      "items": { "$ref": "#/$defs/featureHangdangCell" },
      "description": "全局特征-行当共现矩阵（热力图/桑基图）"
    },
    "by_collection": {
      "type": "array",
      "items": { "$ref": "#/$defs/collectionRoleStats" }
    },
    "by_era_bucket": {
      "type": "array",
      "items": { "$ref": "#/$defs/eraRoleStats" }
    },
    "inference_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/inferenceResult" },
      "description": "未标注人物推断结果（可跨剧本汇总）"
    }
  },
  "$defs": {
    "featureHangdangCell": {
      "type": "object",
      "required": ["feature", "hangdang", "count"],
      "additionalProperties": false,
      "properties": {
        "feature": {
          "type": "string",
          "description": "feature=value",
          "examples": ["gender=男"]
        },
        "hangdang": {
          "$ref": "../common/definitions.schema.json#/$defs/hangdang"
        },
        "count": { "type": "integer", "minimum": 0 },
        "ratio": {
          "$ref": "../common/definitions.schema.json#/$defs/confidence",
          "description": "占该 hangdang 或该 feature 的比例"
        }
      }
    },
    "collectionRoleStats": {
      "type": "object",
      "required": ["collection_id", "collection_name", "hangdang_distribution"],
      "additionalProperties": false,
      "properties": {
        "collection_id": {
          "$ref": "../common/definitions.schema.json#/$defs/collectionId"
        },
        "collection_name": { "type": "string" },
        "hangdang_distribution": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "trait_hangdang_links": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["trait", "hangdang"],
            "properties": {
              "trait": { "type": "string" },
              "hangdang": {
                "$ref": "../common/definitions.schema.json#/$defs/hangdang"
              },
              "count": { "type": "integer", "minimum": 0 },
              "pmi": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "play_count": { "type": "integer", "minimum": 0 }
      }
    },
    "eraRoleStats": {
      "type": "object",
      "required": ["era", "hangdang_distribution"],
      "additionalProperties": false,
      "properties": {
        "era": {
          "type": "string",
          "description": "时代分桶标签",
          "examples": ["清代", "民国", "三国"]
        },
        "hangdang_distribution": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "play_count": { "type": "integer", "minimum": 0 }
      }
    },
    "inferenceResult": {
      "type": "object",
      "required": [
        "script_id",
        "character_id",
        "hangdang_inferred",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "script_id": {
          "$ref": "../common/definitions.schema.json#/$defs/scriptId"
        },
        "character_id": { "type": "string", "pattern": "^c_" },
        "name": { "type": "string" },
        "hangdang_inferred": {
          "$ref": "../common/definitions.schema.json#/$defs/hangdang"
        },
        "confidence": {
          "$ref": "../common/definitions.schema.json#/$defs/confidence"
        },
        "top_features": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
