{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cs3320.local/schemas/analytics/play_role.schema.json",
  "title": "PlayRoleAnalysis",
  "description": "单剧本行当分析 — artifacts/analytics/plays/{script_id}/role.json",
  "type": "object",
  "required": ["script_id", "characters", "hangdang_distribution"],
  "additionalProperties": false,
  "properties": {
    "script_id": {
      "$ref": "../common/definitions.schema.json#/$defs/scriptId"
    },
    "hangdang_distribution": {
      "$ref": "#/$defs/hangdangCountMap",
      "description": "本剧各行当人物数量"
    },
    "hangdang_coarse_distribution": {
      "$ref": "#/$defs/hangdangCoarseCountMap"
    },
    "characters": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "#/$defs/characterRoleResult" }
    },
    "trait_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/traitHangdangLink" },
      "description": "本剧特征-行当关联（样本较少时可为空）"
    },
    "labeled_count": {
      "type": "integer",
      "minimum": 0,
      "description": "已带 hangdang_labeled 的角色数"
    },
    "inferred_count": {
      "type": "integer",
      "minimum": 0,
      "description": "通过分析推断出行当（非「未知」）的角色数"
    }
  },
  "$defs": {
    "hangdangCountMap": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      },
      "description": "键为 hangdang 枚举值，值为计数"
    },
    "hangdangCoarseCountMap": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "characterRoleResult": {
      "type": "object",
      "required": ["character_id", "name"],
      "additionalProperties": false,
      "properties": {
        "character_id": {
          "type": "string",
          "pattern": "^c_"
        },
        "name": { "type": "string" },
        "hangdang_labeled": {
          "oneOf": [
            { "$ref": "../common/definitions.schema.json#/$defs/hangdang" },
            { "type": "null" }
          ]
        },
        "hangdang_inferred": {
          "oneOf": [
            { "$ref": "../common/definitions.schema.json#/$defs/hangdang" },
            { "type": "null" }
          ]
        },
        "hangdang_final": {
          "$ref": "../common/definitions.schema.json#/$defs/hangdang",
          "description": "labeled 优先，否则取 inferred"
        },
        "confidence": {
          "$ref": "../common/definitions.schema.json#/$defs/confidence"
        },
        "top_features": {
          "type": "array",
          "items": { "type": "string" },
          "description": "如 identity=将、personality=诙谐",
          "examples": [["identity=将", "performance_cues=唱"]]
        },
        "traits_derived": {
          "$ref": "../common/definitions.schema.json#/$defs/traits",
          "description": "由分析侧从台词/上下文抽取的扩展特征"
        }
      }
    },
    "traitHangdangLink": {
      "type": "object",
      "required": ["trait", "hangdang", "count"],
      "additionalProperties": false,
      "properties": {
        "trait": {
          "type": "string",
          "description": "feature=value 形式",
          "examples": ["gender=男", "identity=将"]
        },
        "hangdang": {
          "$ref": "../common/definitions.schema.json#/$defs/hangdang"
        },
        "count": { "type": "integer", "minimum": 0 },
        "pmi": {
          "type": "number",
          "description": "特征与行当的点互信息（可选）"
        }
      }
    }
  }
}
