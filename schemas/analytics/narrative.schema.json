{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cs3320.local/schemas/analytics/narrative.schema.json",
  "title": "PlayNarrativeAnalysis",
  "description": "单剧本叙事结构分析 — artifacts/analytics/plays/{script_id}/narrative.json",
  "type": "object",
  "required": [
    "script_id",
    "plot_stages",
    "rhythm_series",
    "performance_mark_distribution"
  ],
  "additionalProperties": false,
  "properties": {
    "script_id": {
      "$ref": "../common/definitions.schema.json#/$defs/scriptId"
    },
    "title": { "type": "string" },
    "plot_stages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/plotStage" },
      "description": "情节阶段划分"
    },
    "rhythm_series": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rhythmPoint" },
      "description": "沿叙事进度的节奏时间序列"
    },
    "performance_mark_distribution": {
      "$ref": "#/$defs/performanceCountMap",
      "description": "全剧唱念做打统计"
    },
    "performance_by_stage": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "distribution"],
        "properties": {
          "stage": {
            "$ref": "../common/definitions.schema.json#/$defs/plotStage"
          },
          "distribution": { "$ref": "#/$defs/performanceCountMap" }
        },
        "additionalProperties": false
      }
    },
    "block_annotations": {
      "type": "array",
      "items": { "$ref": "#/$defs/blockAnnotation" },
      "description": "块级标注（可选，供前端剧本条带视图）"
    }
  },
  "$defs": {
    "plotStage": {
      "type": "object",
      "required": ["stage", "block_range"],
      "additionalProperties": false,
      "properties": {
        "stage": {
          "$ref": "../common/definitions.schema.json#/$defs/plotStage"
        },
        "label": {
          "type": "string",
          "description": "阶段细粒度标签，如「设局」「对质」"
        },
        "block_range": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 0 },
          "description": "闭区间 [start, end] block_index"
        },
        "summary": { "type": "string" }
      }
    },
    "rhythmPoint": {
      "type": "object",
      "required": ["block_index"],
      "additionalProperties": false,
      "properties": {
        "block_index": {
          "type": "integer",
          "minimum": 0,
          "description": "采样点对应的 block_index"
        },
        "window": {
          "type": "integer",
          "minimum": 1,
          "description": "滑动窗口大小（块数）"
        },
        "action_intensity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "做/打等动作强度"
        },
        "dialogue_density": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "对白密度"
        },
        "aria_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "唱段占比"
        },
        "emotion_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "情感强度（情感分析或规则）"
        },
        "tension_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "冲突/紧张度（可选）"
        }
      }
    },
    "performanceCountMap": {
      "type": "object",
      "properties": {
        "唱": { "type": "integer", "minimum": 0 },
        "念": { "type": "integer", "minimum": 0 },
        "做": { "type": "integer", "minimum": 0 },
        "打": { "type": "integer", "minimum": 0 },
        "unknown": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "blockAnnotation": {
      "type": "object",
      "required": ["block_index"],
      "additionalProperties": false,
      "properties": {
        "block_index": { "type": "integer", "minimum": 0 },
        "block_id": { "type": "string", "pattern": "^b_" },
        "stage": {
          "$ref": "../common/definitions.schema.json#/$defs/plotStage"
        },
        "emotion_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "dominant_topic_id": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
