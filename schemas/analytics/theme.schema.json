{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cs3320.local/schemas/analytics/theme.schema.json",
  "title": "PlayThemeAnalysis",
  "description": "单剧本主题分析 — artifacts/analytics/plays/{script_id}/themes.json",
  "type": "object",
  "required": ["script_id", "topics", "topic_composition"],
  "additionalProperties": false,
  "properties": {
    "script_id": {
      "$ref": "../common/definitions.schema.json#/$defs/scriptId"
    },
    "title": { "type": "string" },
    "model": {
      "type": "object",
      "description": "主题模型元信息",
      "properties": {
        "method": {
          "type": "string",
          "enum": ["lda", "nmf", "keyword", "llm", "other"],
          "description": "建模方法"
        },
        "num_topics_global": {
          "type": "integer",
          "minimum": 1,
          "description": "全局主题模型 K 值"
        },
        "trained_at": {
          "$ref": "../common/definitions.schema.json#/$defs/isoDateTime"
        }
      },
      "additionalProperties": false
    },
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/topic" }
    },
    "topic_composition": {
      "type": "array",
      "items": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "description": "与 topics 顺序对应的全剧主题占比向量，元素之和宜为 1"
    },
    "representative_blocks": {
      "type": "array",
      "items": { "$ref": "#/$defs/representativeBlock" },
      "description": "各主题代表性文本片段"
    },
    "quality": {
      "type": "object",
      "description": "主题分析质量评估（可选）",
      "additionalProperties": false,
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "综合质量分 0–1"
        },
        "labeled_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "已识别主题权重占比"
        },
        "fallback_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "未识别（其他情节等）权重占比"
        },
        "keyword_signal_avg": { "type": "number", "minimum": 0, "maximum": 1 },
        "tier_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "method": { "type": "string" },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        },
        "topic_assessments": {
          "type": "array",
          "items": { "$ref": "#/$defs/topicAssessment" }
        }
      }
    }
  },
  "$defs": {
    "topicAssessment": {
      "type": "object",
      "required": ["topic_id", "label", "tier", "label_score", "keyword_signal", "weight"],
      "additionalProperties": false,
      "properties": {
        "topic_id": { "type": "integer", "minimum": 0 },
        "label": { "type": "string" },
        "tier": {
          "type": "string",
          "enum": ["strong", "weak", "fallback", "noise"],
          "description": "strong=规则强命中, weak=弱命中, fallback=未识别, noise=文献噪声"
        },
        "label_score": { "type": "number", "minimum": 0 },
        "keyword_signal": { "type": "number", "minimum": 0, "maximum": 1 },
        "weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "topic": {
      "type": "object",
      "required": ["topic_id", "label", "weight", "keywords"],
      "additionalProperties": false,
      "properties": {
        "topic_id": {
          "type": "integer",
          "minimum": 0,
          "description": "主题编号，全局模型内唯一"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "人工或自动生成的主题短标签",
          "examples": ["忠义", "谋略", "爱情"]
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "该主题在本剧中的权重"
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "maxItems": 30,
          "description": "主题关键词"
        },
        "keyword_weights": {
          "type": "array",
          "items": { "type": "number" },
          "description": "与 keywords 等长的权重（可选）"
        }
      }
    },
    "representativeBlock": {
      "type": "object",
      "required": ["topic_id", "block_id", "text_snippet"],
      "additionalProperties": false,
      "properties": {
        "topic_id": { "type": "integer", "minimum": 0 },
        "block_id": { "type": "string", "pattern": "^b_" },
        "block_index": { "type": "integer", "minimum": 0 },
        "text_snippet": {
          "type": "string",
          "maxLength": 500,
          "description": "截断后的代表性片段"
        },
        "context_snippet": {
          "type": "string",
          "maxLength": 800,
          "description": "拼接前后若干块的上下文片段"
        },
        "speaker_id": {
          "oneOf": [
            { "type": "string", "pattern": "^c_" },
            { "type": "null" }
          ],
          "description": "代表块的说话人 ID（可为空）"
        },
        "speaker_name": {
          "type": "string",
          "description": "代表块的说话人姓名"
        },
        "score": {
          "type": "number",
          "description": "该块属于此主题的概率/得分"
        }
      }
    }
  }
}
