{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cs3320.local/schemas/analytics/network.schema.json",
  "title": "PlayNetwork",
  "description": "单剧本人物关系网络 — artifacts/analytics/plays/{script_id}/network.json",
  "type": "object",
  "required": ["script_id", "nodes", "links", "metrics"],
  "additionalProperties": false,
  "properties": {
    "script_id": {
      "$ref": "../common/definitions.schema.json#/$defs/scriptId"
    },
    "title": { "type": "string" },
    "genre": {
      "$ref": "../common/definitions.schema.json#/$defs/genre"
    },
    "nodes": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "#/$defs/networkNode" }
    },
    "links": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "#/$defs/networkLink" }
    },
    "metrics": {
      "$ref": "#/$defs/networkMetrics"
    }
  },
  "$defs": {
    "networkNode": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^c_",
          "description": "与 character_id 一致"
        },
        "name": { "type": "string" },
        "hangdang": {
          "$ref": "../common/definitions.schema.json#/$defs/hangdang"
        },
        "hangdang_coarse": {
          "$ref": "../common/definitions.schema.json#/$defs/hangdangCoarse"
        },
        "is_main": { "type": "boolean" },
        "degree": {
          "type": "integer",
          "minimum": 0,
          "description": "无权度（拓扑相邻数）"
        },
        "weighted_degree": {
          "type": "number",
          "minimum": 0,
          "description": "加权度（边权之和）"
        },
        "betweenness": {
          "type": "number",
          "minimum": 0,
          "description": "无权介数中心性"
        },
        "weighted_betweenness": {
          "type": "number",
          "minimum": 0,
          "description": "带权介数中心性（按 weight 当距离倒数）"
        },
        "closeness": {
          "type": "number",
          "minimum": 0,
          "description": "接近中心性（可选）"
        },
        "eigenvector": {
          "type": "number",
          "minimum": 0,
          "description": "特征向量中心性（可选）"
        },
        "community_id": {
          "type": "integer",
          "description": "社区划分编号（可选）"
        }
      }
    },
    "networkLink": {
      "type": "object",
      "required": ["source", "target", "weight"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string", "pattern": "^c_" },
        "target": { "type": "string", "pattern": "^c_" },
        "weight": {
          "type": "number",
          "minimum": 0
        },
        "types": {
          "type": "array",
          "items": {
            "$ref": "../common/definitions.schema.json#/$defs/relationType"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "dialogue_count": { "type": "integer", "minimum": 0 },
        "normalized_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "weight / max(weight)，便于前端线粗细映射"
        }
      }
    },
    "networkMetrics": {
      "type": "object",
      "required": ["node_count", "edge_count"],
      "additionalProperties": false,
      "properties": {
        "node_count": { "type": "integer", "minimum": 0 },
        "edge_count": { "type": "integer", "minimum": 0 },
        "density": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "avg_clustering": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "无权聚类系数（Watts-Strogatz）"
        },
        "avg_weighted_clustering": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "带权聚类系数（Holme-Saramäki）"
        },
        "avg_degree": {
          "type": "number",
          "minimum": 0,
          "description": "无权拓扑平均度 = 2m/n"
        },
        "avg_weighted_degree": {
          "type": "number",
          "minimum": 0,
          "description": "带权平均度 = 边权之和×2 / n"
        },
        "modularity": { "type": "number" },
        "assortativity_hangdang": {
          "type": "number",
          "description": "按 hangdang_coarse 的属性同配性 (-1 到 1)"
        },
        "component_count": { "type": "integer", "minimum": 1 },
        "main_subgraph": {
          "type": "object",
          "additionalProperties": false,
          "description": "仅保留 is_main=true 的子图指标",
          "properties": {
            "node_count": { "type": "integer", "minimum": 0 },
            "edge_count": { "type": "integer", "minimum": 0 },
            "density": { "type": "number", "minimum": 0, "maximum": 1 },
            "avg_clustering": { "type": "number", "minimum": 0, "maximum": 1 },
            "modularity": { "type": "number" }
          }
        }
      }
    }
  }
}
