{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cs3320.local/schemas/cleaned/block.schema.json",
  "title": "Block",
  "description": "剧本正文最小单元（对白、舞台说明、唱段等）",
  "type": "object",
  "required": ["block_id", "block_index", "type", "text"],
  "additionalProperties": false,
  "properties": {
    "block_id": {
      "$ref": "../common/definitions.schema.json#/$defs/entityId",
      "pattern": "^b_",
      "description": "块 ID，建议格式 b_{block_index}"
    },
    "block_index": {
      "type": "integer",
      "minimum": 0,
      "description": "全剧顺序索引，从 0 递增，叙事分析依赖此字段"
    },
    "scene_id": {
      "oneOf": [
        { "$ref": "../common/definitions.schema.json#/$defs/entityId" },
        { "type": "null" }
      ],
      "description": "所属场次 ID；未能识别场次时为 null"
    },
    "type": {
      "$ref": "../common/definitions.schema.json#/$defs/blockType"
    },
    "speaker_id": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^c_"
        },
        { "type": "null" }
      ],
      "description": "说话人 character_id；舞台说明等为 null"
    },
    "speaker_name_raw": {
      "type": "string",
      "description": "PDF 中原始说话人标注（便于纠错）"
    },
    "text": {
      "type": "string",
      "description": "块文本内容"
    },
    "performance_tags": {
      "type": "array",
      "items": { "$ref": "../common/definitions.schema.json#/$defs/performanceTag" },
      "uniqueItems": true,
      "default": [],
      "description": "表演类型标记"
    },
    "char_len": {
      "type": "integer",
      "minimum": 0,
      "description": "文本字符数"
    },
    "page_no": {
      "type": "integer",
      "minimum": 1,
      "description": "来源 PDF 页码（可选）"
    }
  }
}
