{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cs3320.local/schemas/cleaned/play.schema.json",
  "title": "Play",
  "description": "单剧本清洗结果 — artifacts/cleaned/plays/{script_id}.json",
  "type": "object",
  "required": [
    "script_id",
    "title",
    "collection_id",
    "collection_name",
    "metadata",
    "characters",
    "blocks"
  ],
  "additionalProperties": false,
  "properties": {
    "script_id": {
      "$ref": "../common/definitions.schema.json#/$defs/scriptId"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "collection_id": {
      "$ref": "../common/definitions.schema.json#/$defs/collectionId"
    },
    "collection_name": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "$ref": "#/$defs/playMetadata"
    },
    "tags": {
      "$ref": "../common/definitions.schema.json#/$defs/tags"
    },
    "characters": {
      "type": "array",
      "items": { "$ref": "character.schema.json" },
      "minItems": 0
    },
    "scenes": {
      "type": "array",
      "items": { "$ref": "scene.schema.json" },
      "default": []
    },
    "blocks": {
      "type": "array",
      "items": { "$ref": "block.schema.json" },
      "minItems": 1
    },
    "cooccurrence_edges_raw": {
      "type": "array",
      "items": { "$ref": "cooccurrence_edge.schema.json" },
      "default": [],
      "description": "预处理抽取的共现边，供 analytics/network 消费"
    }
  },
  "$defs": {
    "playMetadata": {
      "type": "object",
      "required": ["source_pdf", "parse_version"],
      "additionalProperties": false,
      "properties": {
        "source_pdf": {
          "type": "string",
          "minLength": 1
        },
        "parse_version": {
          "type": "string",
          "minLength": 1,
          "examples": ["1.0"]
        },
        "parsed_at": {
          "$ref": "../common/definitions.schema.json#/$defs/isoDateTime"
        },
        "page_count": {
          "type": "integer",
          "minimum": 0
        },
        "char_count": {
          "type": "integer",
          "minimum": 0
        },
        "parse_quality": {
          "$ref": "../common/definitions.schema.json#/$defs/confidence"
        },
        "ocr_used": {
          "type": "boolean",
          "default": false,
          "description": "是否使用 OCR 兜底"
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "解析告警信息"
        }
      }
    }
  }
}
