  "representative_blocks": [
    {
      "topic_id": 0,
      "block_id": "b_60",
      "block_index": 60,
      "text_snippet": "玉旨下，跪。",
      "context_snippet": "（孙尚香上，四水旗引龙王同上。）  /  » 玉旨下，跪。  /  在。",
      "speaker_id": "c_龙王",
      "speaker_name": "龙王",
      "score": 1.0
    },
    {
      "topic_id": 0,
      "block_id": "b_32",
      "block_index": 32,
      "text_snippet": "可叹你当阳道夏口夜奔，",
      "context_snippet": "可叹你水镜庄得一贤伦；  /  » 可叹你当阳道夏口夜奔，  /  可叹你全仗着诸葛先生；",
      "speaker_id": "c_孙尚香",
      "speaker_name": "孙尚香",
      "score": 1.0
    },
    {
      "topic_id": 1,
      "block_id": "b_65",
      "block_index": 65,
      "text_snippet": "众神将，保我朝见玉帝去者。",
      "context_snippet": "（龙王下。孙尚香换衣。）  /  » 众神将，保我朝见玉帝去者。  /  （孙尚香、四水旗同下。）",
      "speaker_id": "c_孙尚香",
      "speaker_name": "孙尚香",
      "score": 1.0
    },
    {
      "topic_id": 1,
      "block_id": "b_62",
      "block_index": 62,
      "text_snippet": "听宣读。诏曰：孙尚香为夫投江，尽节一死，玉帝垂怜，封为枭姬娘娘。旨意读罢，望诏谢恩。",
      "context_snippet": "在。  /  » 听宣读。诏曰：孙尚香为夫投江，尽节一死，玉帝垂怜，封为枭姬娘娘。旨意读罢，望诏谢恩。  /  圣寿无疆。",
      "speaker_id": "c_龙王",
      "speaker_name": "龙王",
      "score": 1.0
    },
    {
      "topic_id": 2,
      "block_id": "b_22",
      "block_index": 22,
      "text_snippet": "夫君，先主！啊呀！",
      "context_snippet": "孙尚香在江边心中酸疼，  /  » 夫君，先主！啊呀！  /  尊一声汉皇叔细听分明：",
      "speaker_id": "c_孙尚香",
      "speaker_name": "孙尚香",
      "score": 1.0
    },
    {
      "topic_id": 2,
      "block_id": "b_19",
      "block_index": 19,
      "text_snippet": "夫君，先主！",
      "context_snippet": "设祭长江岸，举目望西川。梦魂何日见，  /  » 夫君，先主！  /  空自珠泪涟。",
      "speaker_id": "c_孙尚香",
      "speaker_name": "孙尚香",
      "score": 1.0
    }
  ],
