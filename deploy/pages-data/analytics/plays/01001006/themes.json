  "representative_blocks": [
    {
      "topic_id": 0,
      "block_id": "b_59",
      "block_index": 59,
      "text_snippet": "公台，你可知朝中谁忠谁奸？",
      "context_snippet": "管叫他弃县令随我逃脱。  /  » 公台，你可知朝中谁忠谁奸？  /  我在廉外为官，怎知朝内之事？",
      "speaker_id": "c_曹操",
      "speaker_name": "曹操",
      "score": 1.0
    },
    {
      "topic_id": 0,
      "block_id": "b_53",
      "block_index": 53,
      "text_snippet": "也非亲眼得见，现有董太师钧旨，捉拿与你，还敢强辩不成？",
      "context_snippet": "我行刺董太师，可是你亲眼得见？  /  » 也非亲眼得见，现有董太师钧旨，捉拿与你，还敢强辩不成？  /  吓！",
      "speaker_id": "c_陈宫",
      "speaker_name": "陈宫",
      "score": 1.0
    },
    {
      "topic_id": 1,
      "block_id": "b_94",
      "block_index": 94,
      "text_snippet": "思一思想一想无计安妥，",
      "context_snippet": "若不放又恐怕惹出风波。  /  » 思一思想一想无计安妥，  /  我就是放也说个言投意合。",
      "speaker_id": "c_陈宫",
      "speaker_name": "陈宫",
      "score": 1.0
    },
    {
      "topic_id": 1,
      "block_id": "b_485",
      "block_index": 485,
      "text_snippet": "——陈宫题。呀，他有意留诗在此，叫骂与我。陈宫吓，陈宫，我日后若不杀你，誓不为人也！吓，店家，房饭钱在此，俺赶路去了！",
      "context_snippet": "“鼓打四更月正浓，心猿意马归旧宗。误杀吕家人数口，方知曹操是奸雄！”  /  » ——陈宫题。呀，他有意留诗在此，叫骂与我。陈宫吓，陈宫，我日后若不杀你，誓不为人也！吓，店家，房饭钱在此，俺赶路去了！",
      "speaker_id": "c_曹操",
      "speaker_name": "曹操",
      "score": 1.0
    },
    {
      "topic_id": 2,
      "block_id": "b_84",
      "block_index": 84,
      "text_snippet": "捉虎难放虎易自己揣摩！",
      "context_snippet": "擒住你反放你必定伤我，  /  » 捉虎难放虎易自己揣摩！  /  你将我解进京献与董卓，",
      "speaker_id": "c_陈宫",
      "speaker_name": "陈宫",
      "score": 1.0
    },
    {
      "topic_id": 2,
      "block_id": "b_66",
      "block_index": 66,
      "text_snippet": "到如今收吕布做事太错，",
      "context_snippet": "满朝中文共武木雕泥塑。  /  » 到如今收吕布做事太错，  /  一心要谋取那汉室山河。",
      "speaker_id": "c_曹操",
      "speaker_name": "曹操",
      "score": 1.0
    },
    {
      "topic_id": 3,
      "block_id": "b_55",
      "block_index": 55,
      "text_snippet": "听他言唬得我心似刀割，",
      "context_snippet": "吓！  /  » 听他言唬得我心似刀割，  /  心问口口问心自己揣摩。",
      "speaker_id": "c_曹操",
      "speaker_name": "曹操",
      "score": 1.0
    },
    {
      "topic_id": 3,
      "block_id": "b_483",
      "block_index": 483,
      "text_snippet": "天已明了，陈宫为何不见？桌上现有诗句，待我看来：",
      "context_snippet": "不见陈宫事有差。  /  » 天已明了，陈宫为何不见？桌上现有诗句，待我看来：  /  “鼓打四更月正浓，心猿意马归旧宗。误杀吕家人数口，方知曹操是奸雄！”",
      "speaker_id": "c_曹操",
      "speaker_name": "曹操",
      "score": 1.0
    }
