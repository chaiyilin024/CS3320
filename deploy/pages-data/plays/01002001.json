      "scene_id": "s_5",
      "type": "dialogue",
      "speaker_id": "c_四老军",
      "text": "雁来了。",
      "performance_tags": [
        "念"
      ],
      "char_len": 4,
      "speaker_name_raw": "四老军",
      "performance_cues_raw": [
        "同白"
      ],
      "page_no": 3
    },
