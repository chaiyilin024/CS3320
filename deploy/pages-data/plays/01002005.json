      "type": "stage_direction",
      "speaker_id": null,
      "text": "（一名：《杏元和番》；一名：《二度梅》）",
      "performance_tags": [],
      "char_len": 20,
      "page_no": 1
    },
    {
      "block_id": "b_1",
      "block_index": 1,
      "scene_id": null,
