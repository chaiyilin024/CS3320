      "speaker_id": null,
      "text": "（邹云英下。）",
      "performance_tags": [
        "做"
      ],
      "char_len": 7,
      "page_no": 3
    },
    {
      "block_id": "b_124",
      "block_index": 124,
      "scene_id": null,
      "type": "aria",
      "speaker_id": "c_陈杏元",
      "text": "我的梅郎呀！",
      "performance_tags": [
        "唱",
        "念"
      ],
      "char_len": 6,
      "speaker_name_raw": "陈杏元",
      "performance_cues_raw": [
