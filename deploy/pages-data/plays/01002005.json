      "block_index": 122,
      "scene_id": null,
      "type": "dialogue",
      "speaker_id": "c_陈杏元",
      "text": "如此，贤妹请。",
      "performance_tags": [
        "念"
      ],
      "char_len": 7,
      "speaker_name_raw": "陈杏元",
      "performance_cues_raw": [
